# ===========================================
# Analytics & Monitoring
# ===========================================
NEXT_PUBLIC_MEASUREMENT_ID=
NEXT_PUBLIC_SELINE_ENABLED=true
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=true

# PostHog Analytics (optional - leave empty to disable)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===========================================
# Application Settings
# ===========================================
NEXT_PUBLIC_TITLE=ClickHouse Monitoring
NEXT_PUBLIC_TITLE_SHORT=ClickHouse

# ===========================================
# ClickHouse Connection
# ===========================================
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_NAME=
CLICKHOUSE_TZ=
CLICKHOUSE_MAX_EXECUTION_TIME=60

# ===========================================
# Caching & Performance
# ===========================================
NEXT_QUERY_CACHE_TTL=86400
CLICKHOUSE_EXCLUDE_USER_DEFAULT=

# ===========================================
# Logging
# ===========================================
# Enable verbose debug logging in any environment
# Set to 'true' to enable debug output in production
DEBUG=false

# ===========================================
# LangGraph Agent Configuration
# ===========================================
# API key for LLM provider (Anthropic, OpenAI, etc.)
LLM_API_KEY=

# Base URL for LLM API
# Anthropic: https://api.anthropic.com
# OpenAI: https://api.openai.com
# Azure OpenAI: https://your-resource.openai.azure.com
# OpenRouter: https://openrouter.ai/api/v1 (supports multiple providers)
LLM_API_BASE=https://openrouter.ai/api/v1

# Model to use for agent inference
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Default: openrouter/free — a meta-router that auto-selects a working free,
# tool-capable model per request. Survives individual model deprecations.
# Other OpenRouter options (all support tool use):
# - openrouter/auto (auto-router, best quality, paid)
# - z-ai/glm-4.5-air:free (verified reliable free)
# - arcee-ai/trinity-large-preview:free (verified reliable free)
# - qwen/qwen3-coder:free (1M context)
# - qwen/qwen3-next-80b-a3b-instruct:free (262K context)
# - openai/gpt-oss-120b:free / openai/gpt-oss-20b:free
# - meta-llama/llama-3.3-70b-instruct:free
# - google/gemma-4-31b-it:free
# Some free providers require opting-in at https://openrouter.ai/settings/privacy
LLM_MODEL=openrouter/free

# Optional: Maximum tokens for LLM responses
# LLM_MAX_TOKENS=4096

# Optional: Temperature for LLM responses (0.0 - 1.0)
# LLM_TEMPERATURE=0.7

# ===========================================
# OpenRouter App Attribution
# ===========================================
# Optional: App identification headers for OpenRouter rankings/analytics
# See: https://openrouter.ai/docs/app-attribution
OPENROUTER_REFERER=https://clickhouse.duyet.net
OPENROUTER_APP_NAME=ClickHouse Monitoring

# ===========================================
# Clerk Authentication (optional)
# ===========================================
# When configured, enables user authentication via Clerk.
# Get keys from: https://dashboard.clerk.com/
#
# Local/Development - Use TEST keys from Clerk Dashboard
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_test_key_here
# CLERK_SECRET_KEY=sk_test_your_secret_key_here
#
# Production (.env.production.local, GitHub Secrets, Cloudflare) - Use LIVE keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_live_key_here
# CLERK_SECRET_KEY=sk_live_your_secret_key_here