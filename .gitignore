# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# migration state
.migrations/

# testing
/coverage
apps/dashboard/coverage
.nyc_output
/jest-reports
/test-results

# next.js
apps/dashboard/.next/
apps/dashboard/.next-prod/
apps/dashboard/out/
next.config.compiled.js
apps/dashboard/.next/next.config.compiled.js

# production
/build

# external tool artifacts
.entire/
logs/
# ...but `logs/` dirs under the dashboard-tsr SOURCE tree are log-monitoring
# chart components + query-configs, not log output — keep them tracked (the
# `logs/` rule above would otherwise silently drop them from commits).
!apps/dashboard-tsr/src/**/logs/
!apps/dashboard-tsr/src/**/logs/**
!apps/dashboard/components/charts/logs/
!apps/dashboard/components/charts/logs/**
!apps/dashboard/lib/query-config/logs/
!apps/dashboard/lib/query-config/logs/**

# rust build artifacts
rust/target/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env.prod

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cypress
**/cypress/videos
**/cypress/screenshots

# Turborepo
.turbo

# IDE
.idea
.vscode
.env

# Cloudflare
.open-next
.wrangler
.wrangler*.toml
.dev.vars

# Bun local config
bunfig.local.toml

# Generated Rust/WASM bindings
packages/clickhouse-client/src/wasm/generated/*
!packages/clickhouse-client/src/wasm/generated/monitor_core.d.ts
!packages/clickhouse-client/src/wasm/generated/monitor_core.js
!packages/clickhouse-client/src/wasm/generated/monitor_core_bg.wasm
!packages/clickhouse-client/src/wasm/generated/monitor_core_bg.wasm.d.ts
/rust/monitor-core/target/

.claude/*.local.md
.claude/*.local.json
.claude/worktrees/
.cursor
.wrangler
.antigravitycli
.cf-stub-backup/
