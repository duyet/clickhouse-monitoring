{
  "name": "cream",
  "title": "Warm cream — the poetic default",
  "register": "premium-warm",
  "when": "dark / mid-tone warm scenes (band luma < 150): studios, evening interiors, moody interviews. Introspective, narrative, emotional content. The successor of cinematic-cream.",
  "font": {
    "family": "Inter",
    "weights": [500, 600, 700, 900]
  },
  "palette": {
    "scheme": "light-on-dark",
    "cap_color": "#fff5df",
    "blend": "screen",
    "accent": "scene",
    "accent_fallback": "#e3c06a"
  },
  "optics": {
    "depthMatch": true,
    "contactShadow": true,
    "warmBloom": true
  },
  "filter": "contrast(1.08)",
  "motion": {
    "soft": {
      "y": 8,
      "blur": 2.5,
      "dur": 0.5,
      "ease": "power2.out"
    },
    "present": {
      "y": 6,
      "blur": 1.5,
      "scale": 1.03,
      "dur": 0.3,
      "ease": "power3.out"
    },
    "impact": {
      "y": 12,
      "blur": 1.5,
      "scale": 1.08,
      "dur": 0.24,
      "ease": "power4.out"
    },
    "exit": {
      "dur": 0.45,
      "y": -8,
      "ease": "sine.in",
      "stagger": 0
    }
  },
  "hero": {
    "entrance": "emergence",
    "perLetter": true,
    "letterStagger": 0.016,
    "glow": 0.3,
    "dimOthers": 0.45,
    "breathe": 0.012,
    "case": "uppercase",
    "tracking": "-0.03em",
    "sizeRange": [0.2, 0.34],
    "letterBlur": 2.5
  },
  "css": "",
  "deliveries": {
    "home": "column",
    "rail": "validated",
    "note": "standard-mode lineage IS cinematic-cream; validated std renders (jimeng)"
  }
}
