{
  "name": "keynote",
  "title": "Keynote — Apple-grade confidence",
  "register": "tech-premium",
  "when": "product walkthroughs, launches, founder updates, tech explainers. Opaque white type, dead-center planes, few words held long. Confidence comes from mass and stillness, not motion.",
  "font": {
    "family": "Inter",
    "weights": [400, 600, 800]
  },
  "palette": {
    "scheme": "light-on-dark",
    "cap_color": "#ffffff",
    "blend": "normal",
    "accent": "scene",
    "accent_fallback": "#8ab4ff"
  },
  "optics": {
    "depthMatch": true,
    "contactShadow": true,
    "warmBloom": false
  },
  "filter": "none",
  "motion": {
    "soft": {
      "reveal": "burn"
    },
    "present": {
      "reveal": "burn"
    },
    "impact": {
      "reveal": "burn"
    },
    "lineReveal": {
      "type": "wipe-x",
      "dur": 0.4,
      "ease": "expo.out"
    },
    "exit": {
      "dur": 0.3,
      "ease": "power2.in",
      "stagger": 0
    }
  },
  "hero": {
    "entrance": "wipe-up",
    "perLetter": false,
    "letterStagger": 0,
    "glow": 0,
    "dimOthers": 0.35,
    "breathe": 0,
    "case": "uppercase",
    "tracking": "-0.045em",
    "sizeRange": [0.16, 0.3],
    "css": "font-weight: 800;"
  },
  "css": "",
  "deliveries": {
    "home": "column",
    "rail": "validated",
    "note": "wipe-up maps to the std entrance enum; keynote_std validated (Shine)"
  }
}
