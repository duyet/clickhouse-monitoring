{
  "name": "chmonitor",
  "description": "Simple ClickHouse UI that relies on system tables to help monitor and provide overview of your cluster",
  "version": "0.2.9",
  "private": true,
  "workspaces": [
    "apps/dashboard",
    "apps/mcp",
    "packages/*"
  ],
  "packageManager": "bun@1.3.3",
  "engines": {
    "node": ">=22.22.1"
  },
  "repository": {
    "url": "https://github.com/duyet/clickhouse-monitoring"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:landing": "cd apps/landing && bun install --frozen-lockfile && bun run build",
    "build:docs": "cd apps/docs && bun install --frozen-lockfile && bun run build",
    "dev:tsr": "cd apps/dashboard-tsr && bun run dev",
    "build:tsr": "cd apps/dashboard-tsr && bun run build",
    "cf:deploy:tsr": "cd apps/dashboard-tsr && bun run cf:deploy",
    "perf:compare": "bun scripts/perf-compare.ts --skip-build",
    "start": "bun --filter dashboard start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:unit": "bun --filter dashboard test:unit",
    "test:query-config": "bun --filter dashboard test:query-config",
    "test:coverage": "bun --filter dashboard test:coverage && bun run test:packages",
    "test:packages": "bun test packages --isolate --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "test:watch": "bun --filter dashboard test:watch",
    "test:component": "bun --filter dashboard test:component",
    "test:component:headless": "bun --filter dashboard test:component:headless",
    "test:e2e": "bun --filter dashboard test:e2e",
    "test:e2e:headless": "bun --filter dashboard test:e2e:headless",
    "cy:open": "bun --filter dashboard cy:open",
    "cf:build": "bun --filter dashboard cf:build",
    "cf:preview": "bun --filter dashboard cf:preview",
    "cf:deploy": "bun --filter dashboard cf:deploy",
    "cf:config": "bun --filter dashboard cf:config",
    "cf:typegen": "bun --filter dashboard cf:typegen",
    "cf:setup-conversations": "bun --filter dashboard cf:setup-conversations",
    "cf:migrate-conversations": "bun --filter dashboard cf:migrate-conversations",
    "cf:migrate-conversations:local": "bun --filter dashboard cf:migrate-conversations:local",
    "setup:agent-conversations-clickhouse": "bun scripts/create-agent-conversations-clickhouse.ts",
    "cf:health": "bun --filter dashboard cf:health",
    "cf:redirect-rule": "bun scripts/cloudflare-redirect-rule.ts",
    "gh:sync-secrets": "bun --filter dashboard gh:sync-secrets",
    "migrate": "bun --filter dashboard migrate",
    "migrate:status": "bun --filter dashboard migrate:status",
    "migrate:dry-run": "bun --filter dashboard migrate:dry-run",
    "wasm:build": "bun --filter dashboard wasm:build",
    "wasm:test": "bun --filter dashboard wasm:test",
    "rust:build": "bun --filter dashboard rust:build",
    "bench:wasm": "bun --filter dashboard bench:wasm",
    "bench:user-events": "bun --filter dashboard bench:user-events",
    "analyze": "bun --filter dashboard analyze",
    "peerdb:mock": "bun --filter dashboard peerdb:mock",
    "test:agent": "bun --filter dashboard test:agent",
    "docker:health": "docker compose exec app wget -q -O /dev/null http://localhost:3000/api/healthz || exit 1",
    "depcruise": "depcruise apps packages --config .dependency-cruiser.cjs --exclude 'node_modules|\\.next|\\.open-next|dist|\\.turbo|__tests__|\\.test\\.|\\.spec\\.|\\.cy\\.'",
    "build:skills": "bun run scripts/build-skills-registry.ts",
    "preinstall": "npx only-allow bun",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "dependency-cruiser": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "turbo": "^2.9.15",
    "typescript": "^6.0.0"
  },
  "bun": {
    "onlyBuiltDependencies": [
      "cypress",
      "sharp"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,jsonc}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "overrides": {
      "@codemirror/state": "6.6.0",
      "@codemirror/view": "6.43.0",
      "@codemirror/language": "6.12.3",
      "@codemirror/autocomplete": "6.20.2",
      "ajv": "^8.20.0",
      "axios": "^1.16.0",
      "brace-expansion": "^5.0.6",
      "dompurify": "3.4.2",
      "fast-uri": "^4.0.0",
      "fast-xml-parser": "^5.8.0",
      "file-type": "^22.0.1",
      "hono": "^4.12.18",
      "@hono/node-server": "^2.0.0",
      "express-rate-limit": "^8.2.2",
      "ip-address": "^10.2.0",
      "langsmith": "^0.6.0",
      "lodash": "^4.18.1",
      "minimatch": "^10.2.5",
      "path-to-regexp": "^8.4.2",
      "picomatch": "^4.0.3",
      "postcss": "^8.5.15",
      "protobufjs": "8.2.0",
      "@protobufjs/utf8": "^1.1.1",
      "@babel/plugin-transform-modules-systemjs": "^7.29.4",
      "qs": "^6.15.2",
      "serialize-javascript": "^7.0.5",
      "undici": "^8.3.0",
      "uuid": "^14.0.0",
      "zod": "^4.3.6"
    }
  },
  "overrides": {
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.43.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/autocomplete": "6.20.2",
    "@anthropic-ai/sdk": "0.92.0",
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "ajv": "^8.20.0",
    "axios": "^1.16.0",
    "brace-expansion": "^5.0.6",
    "csstype": ">=3.0.0",
    "dompurify": "3.4.2",
    "fast-uri": "^4.0.0",
    "file-type": "^22.0.1",
    "hono": "^4.12.18",
    "@hono/node-server": "^2.0.0",
    "express-rate-limit": "^8.2.2",
    "ip-address": "^10.2.0",
    "langsmith": "^0.6.0",
    "lodash": "^4.18.1",
    "minimatch": "^10.2.5",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.3",
    "postcss": "^8.5.15",
    "protobufjs": "8.2.0",
    "@protobufjs/utf8": "^1.1.1",
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "qs": "^6.15.2",
    "serialize-javascript": "^7.0.5",
    "undici": "^8.3.0",
    "ws": "8.20.1",
    "fast-xml-parser": "^5.8.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  }
}
