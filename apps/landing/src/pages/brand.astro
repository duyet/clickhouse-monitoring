---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const swatches = [
  { name: 'Amber 300', hex: '#fcd34d', role: 'Gradient start · highlights', dark: false },
  { name: 'Amber 500', hex: '#f59e0b', role: 'Gradient mid · accent rule', dark: false },
  { name: 'Orange 500', hex: '#f97316', role: 'Primary brand · theme color', dark: true },
  { name: 'Emerald 500', hex: '#10b981', role: 'Live · healthy · the ping', dark: true },
  { name: 'Ink', hex: '#09090b', role: 'Text · primary buttons', dark: true },
  { name: 'Zinc 500', hex: '#71717a', role: 'Muted text · captions', dark: true },
]

const downloads = [
  { group: 'Logo mark', items: [
    { label: 'Mark — SVG', href: '/brand/logo-mark.svg' },
    { label: 'Mark — PNG 512', href: '/brand/logo-mark-512.png' },
    { label: 'Mark — PNG 1024', href: '/brand/logo-mark-1024.png' },
    { label: 'Mark — monochrome SVG', href: '/brand/logo-mark-mono.svg' },
  ]},
  { group: 'Wordmark lockup', items: [
    { label: 'Lockup — light SVG', href: '/brand/logo.svg' },
    { label: 'Lockup — dark SVG', href: '/brand/logo-dark.svg' },
  ]},
  { group: 'Favicon & app icons', items: [
    { label: 'favicon.svg', href: '/favicon.svg' },
    { label: 'favicon.ico', href: '/favicon.ico' },
    { label: 'apple-touch-icon 180', href: '/apple-touch-icon.png' },
    { label: 'icon 512', href: '/icon-512.png' },
  ]},
  { group: 'Social', items: [
    { label: 'OG image 1200×630', href: '/brand/og-brand.png' },
  ]},
]

// the mark, inlined so CSS `color` can drive the monochrome version
const monoMark = `<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <rect x="1.9" y="1.9" width="28.2" height="28.2" rx="7.4" fill="none" stroke="currentColor" stroke-width="2"/>
  <g fill="currentColor">
    <rect x="6.4" y="17" width="2.7" height="8" rx="1.35"/><rect x="10.6" y="11" width="2.7" height="14" rx="1.35"/>
    <rect x="14.8" y="15" width="2.7" height="10" rx="1.35"/><rect x="19" y="8" width="2.7" height="17" rx="1.35"/>
    <rect x="23.2" y="13" width="2.7" height="12" rx="1.35" fill-opacity=".55"/><circle cx="20.35" cy="5.1" r="1.7"/>
  </g>
</svg>`
---
<Base title="chmonitor — Brand & Logo" description="Download the chmonitor logo, mark, colors and typography. Usage guidelines for the chmonitor brand." image="/brand/og-brand.png">
  <Nav />
  <main id="top">

    <!-- ── hero ── -->
    <section class="b-hero">
      <div class="wrap">
        <p class="eyebrow">Brand</p>
        <h1>Logo &amp; brand assets</h1>
        <p class="b-lead">Everything you need to represent <strong>chmonitor</strong> in docs, posts, talks and integrations. Grab the marks below — please keep the proportions, colors and clear space intact.</p>
        <div class="b-hero-actions">
          <a class="btn btn-primary" href="#downloads">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 11 5 4 5-4"/><path d="M5 21h14"/></svg>
            Download assets
          </a>
          <a class="btn btn-ghost" href="https://github.com/duyet/clickhouse-monitoring" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
      <div class="wrap">
        <div class="b-showcase">
          <img src="/brand/logo.svg" alt="chmonitor logo" width="312" height="66" />
        </div>
      </div>
    </section>

    <!-- ── the mark ── -->
    <section class="band band-soft">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">The mark</p>
          <h2>Columns, monitored live</h2>
          <p>The mark keeps ClickHouse’s columnar DNA — five rounded <strong>columns</strong> — and redraws them as an ascending monitoring signal. The tallest, active column carries an <strong>emerald live‑ping</strong>: the same status dot the product uses to say “healthy, in real time.”</p>
        </div>
        <div class="b-mark-grid">
          <div class="b-mark-cell">
            <img src="/brand/logo-mark.svg" alt="chmonitor mark" width="104" height="104" />
            <span>Primary · gradient</span>
          </div>
          <div class="b-mark-cell b-on-dark">
            <img src="/brand/logo-mark.svg" alt="chmonitor mark on dark" width="104" height="104" />
            <span>On dark surfaces</span>
          </div>
          <div class="b-mark-cell">
            <span class="b-mono b-mono-ink" set:html={monoMark}></span>
            <span>Monochrome · ink</span>
          </div>
          <div class="b-mark-cell b-on-dark">
            <span class="b-mono b-mono-white" set:html={monoMark}></span>
            <span>Monochrome · reversed</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── clear space & sizing ── -->
    <section class="band">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Clear space &amp; size</p>
          <h2>Give it room to breathe</h2>
          <p>Keep clear space around the logo equal to the height of one column (the “<span class="mono">x</span>” unit below). Don’t place type or graphics inside that margin. The mark stays legible down to 16&nbsp;px; below that, use the favicon.</p>
        </div>
        <div class="b-two">
          <div class="b-panel b-clearspace">
            <div class="b-cs-frame">
              <img src="/brand/logo-mark.svg" alt="" width="120" height="120" />
              <span class="b-cs-pad b-cs-t">x</span>
              <span class="b-cs-pad b-cs-b">x</span>
              <span class="b-cs-pad b-cs-l">x</span>
              <span class="b-cs-pad b-cs-r">x</span>
            </div>
            <p class="b-cap">Minimum clear space = 1 column height (x)</p>
          </div>
          <div class="b-panel b-sizes">
            <div class="b-size-row">
              <span class="b-size-box"><img src="/brand/logo-mark.svg" alt="" width="64" height="64" /></span>
              <span class="b-size-box"><img src="/brand/logo-mark.svg" alt="" width="40" height="40" /></span>
              <span class="b-size-box"><img src="/favicon.svg" alt="" width="24" height="24" /></span>
              <span class="b-size-box"><img src="/favicon.svg" alt="" width="16" height="16" /></span>
            </div>
            <p class="b-cap">64 · 40 · 24 · 16 px — favicon kicks in at small sizes</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── color ── -->
    <section class="band band-soft">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Color</p>
          <h2>Amber to orange, with a live pulse</h2>
          <p>The signature is the warm <strong>amber → orange</strong> gradient. Emerald is reserved for the “live / healthy” signal. Neutrals carry the type. Click any value to copy.</p>
        </div>
        <div class="b-grad-card">
          <div class="b-grad"></div>
          <div class="b-grad-meta">
            <b>Primary gradient</b>
            <code class="b-copy" data-copy="linear-gradient(150deg, #fcd34d, #f97316)">linear-gradient(150deg, #fcd34d, #f97316)</code>
          </div>
        </div>
        <div class="b-swatches">
          {swatches.map((s) => (
            <button class="b-swatch b-copy" data-copy={s.hex} type="button">
              <span class="b-chip" style={`background:${s.hex}`}></span>
              <span class="b-sw-name">{s.name}</span>
              <span class="b-sw-hex mono">{s.hex}</span>
              <span class="b-sw-role">{s.role}</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- ── typography ── -->
    <section class="band">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Typography</p>
          <h2>Inter &amp; JetBrains Mono</h2>
          <p>Inter sets every headline and label; JetBrains Mono carries code, metrics and identifiers — the same pairing used across the product.</p>
        </div>
        <div class="b-two">
          <div class="b-panel b-type">
            <div class="b-type-spec" style="font-family:'Inter',sans-serif">Ag</div>
            <div class="b-type-name">Inter</div>
            <div class="b-type-role">Display &amp; UI · 400–700</div>
            <div class="b-type-sample" style="font-family:'Inter',sans-serif">Monitor ClickHouse, live.</div>
          </div>
          <div class="b-panel b-type">
            <div class="b-type-spec mono">Ag</div>
            <div class="b-type-name">JetBrains Mono</div>
            <div class="b-type-role">Code &amp; metrics · 400–600</div>
            <div class="b-type-sample mono">SELECT count() FROM system.parts</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── misuse ── -->
    <section class="band band-soft">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Misuse</p>
          <h2>Please don’t</h2>
          <p>A few quick rules keep the mark recognizable everywhere it shows up.</p>
        </div>
        <div class="b-dont">
          <div class="b-dont-cell"><div class="b-dont-art" style="transform:rotate(14deg)"><img src="/brand/logo-mark.svg" alt="" width="56" height="56" /></div><p>Don’t rotate or skew</p></div>
          <div class="b-dont-cell"><div class="b-dont-art" style="filter:hue-rotate(150deg) saturate(1.4)"><img src="/brand/logo-mark.svg" alt="" width="56" height="56" /></div><p>Don’t recolor the gradient</p></div>
          <div class="b-dont-cell"><div class="b-dont-art b-stretch"><img src="/brand/logo-mark.svg" alt="" width="86" height="44" /></div><p>Don’t stretch or squash</p></div>
          <div class="b-dont-cell"><div class="b-dont-art" style="filter:drop-shadow(0 6px 6px rgba(0,0,0,.5))"><img src="/brand/logo-mark.svg" alt="" width="56" height="56" /></div><p>Don’t add effects or shadows</p></div>
          <div class="b-dont-cell"><div class="b-dont-art b-busy"><img src="/brand/logo-mark.svg" alt="" width="56" height="56" /></div><p>Don’t place on busy backgrounds</p></div>
          <div class="b-dont-cell"><div class="b-dont-art"><svg viewBox="0 0 24 24" width="50" height="50" fill="#f97316"><path d="M21.333 10H24v4h-2.667ZM16 1.335h2.667v21.33H16Zm-5.333 0h2.666v21.33h-2.666ZM0 22.665V1.335h2.667v21.33zm5.333-21.33H8v21.33H5.333Z"/></svg></div><p>Don’t use ClickHouse’s logo for us</p></div>
        </div>
      </div>
    </section>

    <!-- ── downloads ── -->
    <section class="band" id="downloads">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Downloads</p>
          <h2>Grab the files</h2>
          <p>SVG is the source of truth — it scales cleanly and stays crisp. PNGs are provided for places that can’t use SVG.</p>
        </div>
        <div class="b-dl">
          {downloads.map((g) => (
            <div class="b-dl-col">
              <h4>{g.group}</h4>
              {g.items.map((it) => (
                <a class="b-dl-item" href={it.href} download>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 11 5 4 5-4"/><path d="M5 21h14"/></svg>
                  <span>{it.label}</span>
                </a>
              ))}
            </div>
          ))}
        </div>
        <div class="callout">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <span><strong>chmonitor</strong> is an independent open‑source project (GPL‑3.0). It is <strong>not affiliated with, endorsed by, or sponsored by ClickHouse, Inc.</strong> “ClickHouse” is a trademark of ClickHouse, Inc.; the chmonitor mark is its own.</span>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <div id="b-toast" class="b-toast" role="status" aria-live="polite">Copied</div>

  <script is:inline>
    (function () {
      var toast = document.getElementById('b-toast')
      var t
      document.querySelectorAll('.b-copy').forEach(function (el) {
        el.addEventListener('click', function () {
          var v = el.getAttribute('data-copy') || el.textContent.trim()
          if (!navigator.clipboard) return
          navigator.clipboard.writeText(v).then(function () {
            if (!toast) return
            toast.textContent = 'Copied ' + v
            toast.classList.add('on')
            clearTimeout(t)
            t = setTimeout(function () { toast.classList.remove('on') }, 1400)
          })
        })
      })
    })()
  </script>

  <style is:global>
    /* ── brand page ── */
    .b-hero{padding:64px 0 40px;position:relative;overflow:hidden}
    .b-hero::before{content:"";position:absolute;inset:0;z-index:-1;
      background:radial-gradient(ellipse 70% 50% at 50% -30%, rgba(249,115,22,.13), transparent 62%)}
    .b-hero h1{font-size:clamp(34px,5vw,56px);line-height:1.05;letter-spacing:-.03em;font-weight:700;margin-top:14px}
    .b-lead{margin-top:18px;max-width:60ch;font-size:18px;color:var(--muted-fg);text-wrap:pretty}
    .b-lead strong{color:var(--fg);font-weight:600}
    .b-hero-actions{margin-top:26px;display:flex;gap:12px;flex-wrap:wrap}
    .b-showcase{margin-top:44px;border:1px solid var(--border);border-radius:20px;background:
      radial-gradient(120% 120% at 50% 0%, #fff 40%, #fffaf3 100%);
      box-shadow:var(--shadow-card);display:flex;align-items:center;justify-content:center;
      min-height:240px;padding:40px}
    .b-showcase img{width:min(340px,72vw);height:auto}

    /* mark grid */
    .b-mark-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:48px}
    .b-mark-cell{border:1px solid var(--border);border-radius:16px;background:#fff;padding:30px 18px 18px;
      display:flex;flex-direction:column;align-items:center;gap:18px;text-align:center}
    .b-mark-cell img,.b-mark-cell .b-mono{width:88px;height:88px}
    .b-mark-cell span:last-child{font-size:12.5px;color:var(--muted-fg);font-weight:500}
    .b-mark-cell.b-on-dark{background:#0c0c0f;border-color:#1d1d22}
    .b-mark-cell.b-on-dark span:last-child{color:#a1a1aa}
    .b-mono{display:inline-flex}
    .b-mono svg{width:100%;height:100%}
    .b-mono-ink{color:#09090b}
    .b-mono-white{color:#ffffff}

    /* two-up panels */
    .b-two{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:48px}
    .b-panel{border:1px solid var(--border);border-radius:16px;background:#fff;padding:28px;
      display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:240px}
    .b-cap{font-size:12.5px;color:var(--muted-fg);margin-top:20px;text-align:center}

    /* clear space */
    .b-cs-frame{position:relative;padding:46px}
    .b-cs-frame > img{display:block;border:1px dashed #e7c9a3;border-radius:10px}
    .b-cs-pad{position:absolute;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--orange);
      display:flex;align-items:center;justify-content:center}
    .b-cs-t{top:14px;left:0;right:0}
    .b-cs-b{bottom:14px;left:0;right:0}
    .b-cs-l{left:14px;top:0;bottom:0}
    .b-cs-r{right:14px;top:0;bottom:0}

    /* sizes */
    .b-size-row{display:flex;align-items:flex-end;gap:26px}
    .b-size-box{display:flex;align-items:center;justify-content:center}

    /* color */
    .b-grad-card{margin-top:48px;border:1px solid var(--border);border-radius:16px;overflow:hidden;background:#fff;box-shadow:var(--shadow-card)}
    .b-grad{height:120px;background:linear-gradient(150deg,#fcd34d,#f59e0b 55%,#f97316)}
    .b-grad-meta{padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
    .b-grad-meta b{font-size:14px;font-weight:600}
    .b-grad-meta code{font-size:12.5px;background:var(--muted);padding:5px 10px;border-radius:7px;cursor:pointer;color:var(--fg-soft);transition:.15s}
    .b-grad-meta code:hover{background:#ececef;color:var(--fg)}
    .b-swatches{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:16px}
    .b-swatch{display:flex;flex-direction:column;align-items:flex-start;gap:4px;text-align:left;
      border:1px solid var(--border);border-radius:14px;background:#fff;padding:16px;cursor:pointer;transition:.16s ease;font:inherit}
    .b-swatch:hover{border-color:#dcdce0;box-shadow:var(--shadow-card);transform:translateY(-2px)}
    .b-chip{width:100%;height:54px;border-radius:9px;margin-bottom:8px;box-shadow:inset 0 0 0 1px rgba(9,9,11,.06)}
    .b-sw-name{font-size:14px;font-weight:600;letter-spacing:-.01em}
    .b-sw-hex{font-size:12.5px;color:var(--fg-soft)}
    .b-sw-role{font-size:12px;color:var(--muted-fg)}

    /* type */
    .b-type{align-items:flex-start;gap:0}
    .b-type-spec{font-size:78px;line-height:1;font-weight:700;letter-spacing:-.03em;
      background:linear-gradient(150deg,#f59e0b,#f97316);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
    .b-type-name{margin-top:18px;font-size:18px;font-weight:650;font-weight:600}
    .b-type-role{margin-top:4px;font-size:13px;color:var(--muted-fg)}
    .b-type-sample{margin-top:20px;font-size:19px;color:var(--fg-soft);border-top:1px solid var(--border-soft);padding-top:18px;width:100%}

    /* misuse */
    .b-dont{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
    .b-dont-cell{border:1px solid var(--border);border-radius:14px;background:#fff;overflow:hidden}
    .b-dont-art{height:130px;display:flex;align-items:center;justify-content:center;background:var(--bg-soft);border-bottom:1px solid var(--border-soft)}
    .b-dont-art.b-stretch img{width:86px;height:44px}
    .b-dont-art.b-busy{background:
      repeating-linear-gradient(45deg,#f97316,#f97316 10px,#f59e0b 10px,#f59e0b 20px)}
    .b-dont-cell p{font-size:13px;color:var(--fg-soft);padding:14px 16px;display:flex;gap:8px}
    .b-dont-cell p::before{content:"✕";color:#ef4444;font-weight:700}

    /* downloads */
    .b-dl{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:48px}
    .b-dl-col h4{font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--muted-fg);margin-bottom:12px}
    .b-dl-item{display:flex;align-items:center;gap:10px;padding:11px 13px;border:1px solid var(--border);border-radius:10px;
      background:#fff;font-size:13.5px;color:var(--fg-soft);font-weight:500;margin-bottom:9px;transition:.15s}
    .b-dl-item svg{width:16px;height:16px;color:var(--muted-fg);flex:0 0 auto}
    .b-dl-item:hover{border-color:#dcdce0;color:var(--fg);background:var(--bg-soft);transform:translateY(-1px)}
    .b-dl-item:hover svg{color:var(--orange)}

    /* toast */
    .b-toast{position:fixed;left:50%;bottom:28px;transform:translate(-50%,16px);z-index:80;
      background:var(--fg);color:#fff;font-size:13px;font-weight:500;padding:10px 16px;border-radius:10px;
      box-shadow:var(--shadow-float);opacity:0;pointer-events:none;transition:.2s ease}
    .b-toast.on{opacity:1;transform:translate(-50%,0)}

    @media (max-width:880px){
      .b-mark-grid{grid-template-columns:repeat(2,1fr)}
      .b-two{grid-template-columns:1fr}
      .b-swatches{grid-template-columns:repeat(2,1fr)}
      .b-dont{grid-template-columns:repeat(2,1fr)}
      .b-dl{grid-template-columns:repeat(2,1fr)}
    }
    @media (max-width:560px){
      .b-mark-grid,.b-swatches,.b-dont,.b-dl{grid-template-columns:1fr}
    }
  </style>
</Base>
