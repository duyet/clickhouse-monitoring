---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

const swatches = [
  { name: 'Orange', role: 'Metric bars · primary accent', hex: '#f97316', token: '--orange' },
  { name: 'Emerald', role: 'Top-cap dot · healthy signal', hex: '#10b981', token: '--emerald' },
  { name: 'Ink', role: 'Mono mark · text', hex: '#09090b', token: '--fg' },
  { name: 'Paper', role: 'Mono mark on dark · surfaces', hex: '#fafafa', token: '--bg-soft' },
]

const downloads = [
  {
    group: 'Mark',
    items: [
      { label: 'Mark — SVG', href: '/brand/logo-mark.svg' },
      { label: 'Mark — mono SVG', href: '/brand/logo-mark-mono.svg' },
      { label: 'Mark — PNG 512', href: '/brand/logo-mark-512.png' },
      { label: 'Mark — PNG 1024', href: '/brand/logo-mark-1024.png' },
    ],
  },
  {
    group: 'Lockup',
    items: [
      { label: 'Lockup — light SVG', href: '/brand/logo.svg' },
      { label: 'Lockup — dark SVG', href: '/brand/logo-dark.svg' },
    ],
  },
  {
    group: 'Favicon & app icons',
    items: [
      { label: 'favicon.svg', href: '/favicon.svg' },
      { label: 'favicon.ico', href: '/favicon.ico' },
      { label: 'apple-touch 180', href: '/apple-touch-icon.png' },
      { label: 'icon 512', href: '/icon-512.png' },
    ],
  },
  {
    group: 'Social',
    items: [{ label: 'OG image 1200×630', href: '/brand/og-brand.png' }],
  },
]

// Mono mark inlined so CSS `color` drives the ink/paper finish deterministically
// (an <img>-embedded SVG can't be themed by the page).
const monoMark = `<svg viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <rect x="3.3" y="9.75" width="3.8" height="3.3"/><rect x="3.3" y="13.95" width="3.8" height="14.55"/>
  <rect x="8.7" y="3.5" width="3.8" height="25"/><rect x="14.1" y="13.25" width="3.8" height="15.25"/>
  <rect x="19.5" y="6.25" width="3.8" height="22.25"/><rect x="24.9" y="16.8" width="3.8" height="11.7"/>
</svg>`
---
<Base
  title="chmonitor — Brand & Logo"
  description="The chmonitor brand mark, colors and usage. A flat metric-bar glyph with an emerald top-cap dot."
  image="/brand/og-brand.png"
>
  <Nav />
  <main id="top">
    <!-- ── header ── -->
    <section class="hero band-brand">
      <div class="wrap">
        <p class="eyebrow">Brand</p>
        <h1 class="brand-title">A flat metric-bar mark<br />with an emerald top-cap dot.</h1>
        <p class="brand-sub">
          chmonitor's identity is five bars of varying height on ClickHouse's column grid — a
          monitor reading a cluster. The emerald cap on the left bar is the signal: healthy, live, watching.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-sm" href="#downloads">Download assets</a>
          <a class="btn btn-ghost btn-sm" href="/brand/logo-mark.svg" download>Mark (SVG)</a>
        </div>
      </div>
      <div class="wrap">
        <div class="brand-showcase"><img src="/brand/logo.svg" alt="chmonitor logo" width="312" height="66" /></div>
      </div>
    </section>

    <!-- ── the mark ── -->
    <section class="band">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">The mark</p>
          <h2>One glyph, three finishes</h2>
          <p>Color for product surfaces, single-ink mono for documents, and the same mono reversed for dark backgrounds.</p>
        </div>
        <div class="tiles">
          <figure class="tile">
            <div class="tile-art"><img src="/brand/logo-mark.svg" alt="chmonitor color mark" width="92" height="92" /></div>
            <figcaption><strong>Color</strong><span>Orange bars · emerald cap</span></figcaption>
          </figure>
          <figure class="tile">
            <div class="tile-art mono-ink" set:html={monoMark}></div>
            <figcaption><strong>Mono · light</strong><span>Single ink (#09090b)</span></figcaption>
          </figure>
          <figure class="tile tile-dark">
            <div class="tile-art mono-paper" set:html={monoMark}></div>
            <figcaption><strong>Mono · dark</strong><span>Paper ink (#fafafa)</span></figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ── lockup ── -->
    <section class="band band-soft">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Lockup</p>
          <h2>Mark + wordmark</h2>
          <p>The wordmark is set lowercase in Geist SemiBold with tight tracking. Keep the mark roughly the cap-height of the word, with a gap of one bar's width.</p>
        </div>
        <div class="lockups">
          <div class="lockup"><img src="/brand/logo.svg" alt="chmonitor logo" width="208" height="44" /></div>
          <div class="lockup lockup-dark"><img src="/brand/logo-dark.svg" alt="chmonitor logo reversed" width="208" height="44" /></div>
        </div>
      </div>
    </section>

    <!-- ── color ── -->
    <section class="band">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Color</p>
          <h2>Four values, one signal</h2>
          <p>Orange carries the bars, emerald is reserved for the "healthy / live" signal — never decoration. Ink and paper handle everything mono.</p>
        </div>
        <div class="swatches">
          {swatches.map((s) => (
            <div class="swatch">
              <span class="chip" style={`background:${s.hex}`}></span>
              <div class="meta">
                <strong>{s.name}</strong>
                <span class="mono">{s.hex}</span>
                <span class="role">{s.role}</span>
                <code class="mono token">{s.token}</code>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── usage ── -->
    <section class="band band-soft">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Usage</p>
          <h2>Keep it honest</h2>
        </div>
        <div class="rules">
          <ul class="do">
            <li>Give the mark clear space of at least one bar-width on every side.</li>
            <li>Use the emerald cap only at its native position (top of the left bar).</li>
            <li>Prefer the SVG; fall back to the PNG / favicon where SVG isn't supported.</li>
            <li>On dark surfaces, use the reversed mono mark or the color mark as-is.</li>
          </ul>
          <ul class="dont">
            <li>Don't recolor the bars, add gradients, or restore the old tile / ping.</li>
            <li>Don't stretch, rotate, or reorder the bars — the heights are the identity.</li>
            <li>Don't pair the mark with the ClickHouse logo as if it were one brand.</li>
            <li>Don't set the wordmark in any face other than Geist.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ── downloads ── -->
    <section class="band" id="downloads">
      <div class="wrap">
        <div class="sec-head">
          <p class="eyebrow">Downloads</p>
          <h2>Grab the files</h2>
          <p>Everything is generated from one script (<span class="mono">scripts/build-brand-assets.ts</span>) so the kit never drifts from the mark.</p>
        </div>
        <div class="dl-grid">
          {downloads.map((d) => (
            <div class="dl-col">
              <h5>{d.group}</h5>
              {d.items.map((i) => (
                <a href={i.href} download>{i.label}</a>
              ))}
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .band-brand { padding: 64px 0 40px; }
  .brand-title { font-size: clamp(32px, 4.6vw, 52px); line-height: 1.06; letter-spacing: -.03em; font-weight: 700; margin-top: 16px; }
  .brand-sub { margin-top: 18px; max-width: 64ch; font-size: 17.5px; color: var(--muted-fg); text-wrap: pretty; }
  .band-brand .hero-actions { justify-content: flex-start; margin-top: 26px; }
  .brand-showcase { margin-top: 40px; display: flex; align-items: center; justify-content: center; height: 180px;
    border: 1px solid var(--border); border-radius: var(--radius); background: #fff; box-shadow: var(--shadow-card); }

  .tiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 34px; }
  .tile { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: #fff; box-shadow: var(--shadow-card); }
  .tile-art { display: flex; align-items: center; justify-content: center; height: 168px; }
  .tile-art :global(svg) { width: 92px; height: 92px; }
  .mono-ink { color: #09090b; }
  .mono-paper { color: #fafafa; }
  .tile-dark { background: #09090b; border-color: #1f1f23; }
  .tile figcaption { display: flex; flex-direction: column; gap: 2px; padding: 14px 16px; border-top: 1px solid var(--border-soft); }
  .tile-dark figcaption { border-top-color: #1f1f23; }
  .tile figcaption strong { font-size: 14px; font-weight: 600; }
  .tile figcaption span { font-size: 12.5px; color: var(--muted-fg); }
  .tile-dark figcaption strong { color: #fafafa; }
  .tile-dark figcaption span { color: #a1a1aa; }

  .lockups { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 30px; }
  .lockup { display: flex; align-items: center; padding: 30px 40px; border: 1px solid var(--border); border-radius: var(--radius);
    background: #fff; box-shadow: var(--shadow-card); }
  .lockup img { height: 36px; width: auto; }
  .lockup-dark { background: #09090b; border-color: #1f1f23; }

  .swatches { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-top: 34px; }
  .swatch { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: #fff; box-shadow: var(--shadow-card); }
  .swatch .chip { display: block; height: 96px; }
  .swatch .meta { display: flex; flex-direction: column; gap: 4px; padding: 14px 16px; }
  .swatch .meta strong { font-size: 14px; font-weight: 600; }
  .swatch .meta .mono { font-size: 13px; color: var(--fg-soft); }
  .swatch .meta .role { font-size: 12px; color: var(--muted-fg); }
  .swatch .meta .token { font-size: 11.5px; color: var(--muted-fg); background: var(--muted); padding: 2px 6px; border-radius: 6px; width: fit-content; }

  .rules { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 30px; }
  .rules ul { list-style: none; padding: 22px 24px; border-radius: var(--radius); border: 1px solid var(--border); background: #fff; box-shadow: var(--shadow-card); }
  .rules li { position: relative; padding-left: 26px; font-size: 14.5px; color: var(--fg-soft); }
  .rules li + li { margin-top: 12px; }
  .rules li::before { position: absolute; left: 0; top: -1px; font-weight: 700; }
  .rules .do li::before { content: "✓"; color: var(--emerald); }
  .rules .dont li::before { content: "✕"; color: #ef4444; }

  .dl-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 30px; }
  .dl-col h5 { font-size: 12px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--muted-fg); margin-bottom: 12px; }
  .dl-col a { display: block; font-size: 14px; color: var(--fg-soft); padding: 7px 0; border-top: 1px solid var(--border-soft); transition: color .15s; }
  .dl-col a:hover { color: var(--orange); }

  @media (max-width: 860px) {
    .tiles, .swatches, .rules, .dl-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .tiles, .swatches, .rules, .dl-grid { grid-template-columns: 1fr; }
  }
</style>
