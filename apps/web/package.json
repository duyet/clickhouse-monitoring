{
  "name": "web",
  "description": "Simple ClickHouse UI that relies on system tables to help monitor and provide overview of your cluster",
  "version": "0.2.0",
  "private": true,
  "repository": {
    "url": "https://github.com/duyet/clickhouse-monitoring"
  },
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "peerdb:mock": "bun ../../scripts/peerdb-mock-server.ts",
    "build": "NODE_OPTIONS=--max-old-space-size=6144 bun ../../scripts/build-docs-content.ts && bun run wasm:build && NODE_OPTIONS=--max-old-space-size=6144 bun next build --webpack",
    "start": "bun --bun next start",
    "analyze": "ANALYZE=true bun run build",
    "analyze:turbo": "bun next experimental-analyze",
    "cf:build": "bun run build && bun ../../scripts/stub-prerendered-handlers.ts && (opennextjs-cloudflare build --skipBuild && bun ../../scripts/copy-prerendered-to-assets.ts; status=$?; bun ../../scripts/restore-prerendered-handlers.ts; exit $status)",
    "cf:preview": "bun run cf:build && opennextjs-cloudflare preview",
    "cf:config": "bun ../../scripts/set-secrets.ts",
    "gh:sync-secrets": "bun ../../scripts/sync-env-to-gh.ts",
    "cf:setup-conversations": "bun ../../scripts/setup-conversations-db.ts",
    "cf:migrate-conversations": "wrangler d1 migrations apply clickhouse-monitor-conversations --remote --yes",
    "cf:migrate-conversations:local": "wrangler d1 migrations apply clickhouse-monitor-conversations --local --yes",
    "migrate": "bun lib/migration/migration-runner.ts",
    "migrate:status": "bun lib/migration/migration-runner.ts status",
    "migrate:dry-run": "bun lib/migration/migration-runner.ts migrate --dry-run",
    "cf:deploy": "bun ../../scripts/cloudflare-deploy.ts",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:health": "curl -sSf https://chmonitor.dev/api/healthz | jq .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "cy:open": "start-server-and-test dev http://localhost:3000 \"cypress open\"",
    "test:e2e": "start-server-and-test dev http://localhost:3000 \"cypress open --e2e\"",
    "test:e2e:headless": "start-server-and-test dev http://localhost:3000 \"cypress run --e2e\"",
    "test:component": "cypress open --component",
    "test:component:headless": "cypress run --component",
    "fmt": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "bun --smol --env-file=.env.local test --isolate --max-concurrency=1 --preload ./.sisyphus/swr-mock-preload.ts",
    "test:unit": "bun --smol --env-file=.env.local test --isolate --max-concurrency=1 --preload ./.sisyphus/swr-mock-preload.ts lib/__tests__ app/overview/__tests__ components/**/__tests__",
    "test:query-config": "bun --smol test lib/query-config",
    "test:coverage": "bun --smol --env-file=.env.local test --isolate --max-concurrency=1 --preload ./.sisyphus/swr-mock-preload.ts --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "test:watch": "bun --smol test --watch",
    "type-check": "NODE_OPTIONS=--max-old-space-size=6144 tsc --noEmit",
    "wasm:build": "bun ../../scripts/build-wasm.ts",
    "wasm:test": "bun run wasm:build && cargo test --manifest-path ../../rust/monitor-core/Cargo.toml && bun test ./lib/__tests__/monitor-core.wasm.test.ts",
    "rust:build": "cargo build --manifest-path ../../rust/monitor-core/Cargo.toml --release",
    "bench:wasm": "bun run wasm:build && bun run rust:build && bun ../../scripts/bench-wasm.ts",
    "bench:user-events": "bun ../../scripts/benchmarks/user-events-transform-benchmark.mjs",
    "test:agent": "start-server-and-test dev http://localhost:3000 \"promptfoo eval -c ../../tests/agent/promptfooconfig.yaml\""
  },
