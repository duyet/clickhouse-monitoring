{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@chm/types": ["../../packages/types/src"],
      "@chm/types/*": ["../../packages/types/src/*"],
      "@chm/sql-builder": ["../../packages/sql-builder/src"],
      "@chm/sql-builder/*": ["../../packages/sql-builder/src/*"],
      "@chm/platform": ["../../packages/platform/src"],
      "@chm/platform/*": ["../../packages/platform/src/*"],
      "@chm/logger": ["../../packages/logger/src"],
      "@chm/clickhouse-client": ["../../packages/clickhouse-client/src"],
      "@chm/clickhouse-client/*": ["../../packages/clickhouse-client/src/*"],
      "@chm/mcp-server": ["../../packages/mcp-server/src"],
      "@chm/mcp-server/*": ["../../packages/mcp-server/src/*"]
    },
    "types": ["cypress", "node", "cypress-real-events"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    "cypress.d.ts",
    "cypress/support/index.d.ts",
    "next-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".open-next",
    ".turbo",
    ".wrangler",
    ".nyc_output",
    "coverage",
    "cypress.config.ts",
    "cypress",
    "docs",
    "scripts",
    "**/*.cy.ts",
    "**/*.cy.tsx",
    "**/*.wasm.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "__mocks__/**/*.ts",
    "bun.setup.ts"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "ESNext",
      "moduleResolution": "Node"
    }
  }
}
