{
  "name": "dashboard-tsr",
  "description": "TanStack Start dashboard (Cloudflare Workers) — substrate spike for #1393",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "repository": {
    "url": "https://github.com/duyet/clickhouse-monitoring"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "build:node": "BUILD_TARGET=node vite build",
    "start:node": "node .output/server/index.mjs",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf:deploy": "bun run build && wrangler deploy",
    "cf:dry-run": "vite build && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.3.2",
    "@clickhouse/client-web": "^1.18.5",
