# ============================================================================
# .env.cloud — Cloud (SaaS) deploy config for dash.chmonitor.dev
# ============================================================================
# SINGLE SOURCE OF TRUTH for the hosted product's non-secret config.
#
# Consumed by:
#   - vite build  (--mode cloud → CHM_BUILD_ENV=cloud): client values are
#     inlined into the browser bundle. Each VITE_* client var derives from its
#     canonical CHM_* name here (see vite.config.ts), so set the value ONCE.
#   - scripts/patch-wrangler-env.ts: every non-VITE_ key below is injected as a
#     Cloudflare Worker runtime [var] (wrangler.toml no longer declares [vars]).
#
# NON-SECRET ONLY. Secrets (CLICKHOUSE_PASSWORD, CLERK_SECRET_KEY,
# CHM_CONNECTIONS_ENCRYPTION_KEY, *_API_KEY) are set via scripts/set-secrets.ts
# from CI secrets — never here. Private homelab CLICKHOUSE_HOST/USER/NAME stay as
# localhost placeholders and are overridden at deploy from CI secrets.
# ============================================================================

# ── Product mode ────────────────────────────────────────────────────────────
# Cloud (SaaS): env hosts become a public read-only demo; signed-in users get a
# clean per-user workspace. Drives both the server (CHM_CLOUD_MODE) and the
# client (VITE_CLOUD_MODE, derived in vite.config.ts).
CHM_CLOUD_MODE=true
# Per-user ClickHouse connection storage (D1). Requires Clerk + encryption key.
CHM_FEATURE_USER_CONNECTIONS_DB=true
# Persist agent conversations server-side (D1/AgentState) instead of localStorage.
CHM_FEATURE_CONVERSATION_DB=true

# ── Auth ────────────────────────────────────────────────────────────────────
# Single canonical auth provider: drives server (CHM_AUTH_PROVIDER) AND client
# (VITE_AUTH_PROVIDER, derived in vite.config.ts). No more setting it twice.
CHM_AUTH_PROVIDER=clerk
# Public Clerk publishable key (pk_live — public, safe to commit). Drives the
# client VITE_CLERK_PUBLISHABLE_KEY. Preview overrides with pk_test in .env.preview.
CHM_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsuY2htb25pdG9yLmRldiQ
# Public read-only: anonymous visitors can view monitoring data; writes (agent,
# KILL QUERY / OPTIMIZE TABLE, arbitrary SQL) require sign-in.
CHM_CLERK_PUBLIC_READ=true
# AI agent access: public | authenticated.
CHM_FEATURE_AGENT_ACCESS=authenticated

# ── ClickHouse (demo host) ──────────────────────────────────────────────────
# Localhost placeholders — the real demo host topology is injected at deploy from
# CI secrets (CLICKHOUSE_HOST/USER/NAME) so it never lands in the public repo.
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_NAME=localhost
CLICKHOUSE_MAX_EXECUTION_TIME=60

# ── Runtime / platform ──────────────────────────────────────────────────────
# Marks the Cloudflare Worker runtime (set only in the worker, not Docker/Node).
CLOUDFLARE_WORKERS=1
# Default AI model for the hosted product.
LLM_MODEL=anyrouter:@preset/chmonitor
# OpenRouter/AnyRouter attribution (non-secret).
OPENROUTER_REFERER=https://chmonitor.dev
OPENROUTER_APP_NAME=chmonitor
# AgentState conversation-store enrichment (auto-titles + follow-ups). The
# AGENTSTATE_API_KEY secret alone activates the backend; this only tunes it.
AGENTSTATE_AI_ENRICH=true

# ── Client-only (build-time inlined; never a worker var) ────────────────────
# Deployment dimension for telemetry.
VITE_DEPLOY_TARGET=cf
