# ============================================================================
# .env.preview — Cloud (SaaS) PREVIEW deploy config (preview.dash.chmonitor.dev)
# ============================================================================
# Overlay on top of .env.cloud for PR preview deploys. Loaded AFTER .env.cloud
# (vite build --mode preview / CHM_BUILD_ENV=preview; patch-wrangler-env.ts
# --env preview), so only the deltas from production live here.
#
# NON-SECRET ONLY — same rules as .env.cloud.
# ============================================================================

# Cheaper model for preview deploys.
LLM_MODEL=anyrouter:z-ai/glm-4.7-flash
# Preview uses the Clerk pk_test publishable key (separate Clerk instance).
CHM_CLERK_PUBLISHABLE_KEY=pk_test_bWFnbmV0aWMtcmF5LTkwLmNsZXJrLmFjY291bnRzLmRldiQ
