# ============================================================================
# .env.preview — Cloud (SaaS) PREVIEW deploy config (preview.dash.chmonitor.dev)
# ============================================================================
# ✅ COMMITTED TO GIT — NON-SECRET ONLY. Secrets live in a gitignored
#    .env*.local / scripts/set-secrets.ts / a K8s Secret — never here.
# ----------------------------------------------------------------------------
# Overlay on top of .env.production for PR preview deploys. Loaded AFTER .env.production
# (vite build --mode preview / CHM_BUILD_ENV=preview; patch-wrangler-env.ts
# --env preview), so only the deltas from production live here.
#
# NON-SECRET ONLY — same rules as .env.production.
# ============================================================================

# Cheaper, PUBLIC model for preview deploys (no private preset committed).
LLM_MODEL=anyrouter:z-ai/glm-4.7-flash
# Preview Clerk publishable key (pk_test) is NOT committed — keeps the repo
# generic/OSS. chmonitor's preview gets it from the GitHub Actions variable
# CHM_CLERK_PUBLISHABLE_KEY_TEST; local preview builds read .env.preview.local.
# CHM_CLERK_PUBLISHABLE_KEY=pk_test_...
