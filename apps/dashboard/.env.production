# ============================================================================
# .env.production — Cloud (SaaS) production deploy config for dash.chmonitor.dev
# ============================================================================
# ✅ COMMITTED TO GIT — NON-SECRET ONLY. Secrets (passwords, CLERK_SECRET_KEY,
#    CHM_USER_CONNECTIONS_ENCRYPTION_KEY, *_API_KEY) go in a gitignored .env*.local
#    (local) / scripts/set-secrets.ts (Cloudflare) / a K8s Secret — never here.
# ----------------------------------------------------------------------------
# SINGLE SOURCE OF TRUTH for the hosted product's non-secret config.
#
# Consumed by:
#   - vite build  (CHM_BUILD_ENV=production): client values are
#     inlined into the browser bundle. Each VITE_* client var derives from its
#     canonical CHM_* name here (see vite.config.ts), so set the value ONCE.
#   - scripts/patch-wrangler-env.ts: every non-VITE_ key below is injected as a
#     Cloudflare Worker runtime [var] (wrangler.toml no longer declares [vars]).
#
# NON-SECRET ONLY. Secrets (CLICKHOUSE_PASSWORD, CLERK_SECRET_KEY,
# CHM_USER_CONNECTIONS_ENCRYPTION_KEY, *_API_KEY) are set via scripts/set-secrets.ts
# from CI secrets — never here. Private homelab CLICKHOUSE_HOST/USER/NAME stay as
# localhost placeholders and are overridden at deploy from CI secrets.
# ============================================================================

# ── Deployment mode (the ONE high-level switch) ──────────────────────────
# `cloud` picks the whole hosted-SaaS posture in one line (see lib/config/deployment-mode.ts):
#   • cloud mode  → env hosts are a public read-only DEMO (e.g. duet-ubuntu),
#                   owned by the ANONYMOUS visitor; signed-in users get a clean,
#                   empty workspace they populate with their own connections.
#   • auth        → clerk
#   • public-read → anonymous can view everything read-only; writes need sign-in
#   • per-user ClickHouse connections (D1) + server-side conversation storage → on
# Each of those is still overridable by its own CHM_*/VITE_* var below if needed.
CHM_DEPLOYMENT_MODE=cloud

# ── Auth (mode default = clerk; override only to change it) ───────────────
# Clerk publishable key — your OWN Clerk instance, NOT committed (keeps the repo
# generic/OSS). Build-time only (inlined as client VITE_CLERK_PUBLISHABLE_KEY).
#   • CI: set GitHub Actions variable CHM_CLERK_PUBLISHABLE_KEY (pk_live, public).
#   • Local cf:deploy: put it in .env.production.local (folded in by vite.config).
# CHM_CLERK_PUBLISHABLE_KEY=pk_live_...
# AI agent access: public | authenticated. Cloud keeps the agent sign-in-gated
# (anonymous visitors get read-only browsing, not the write-capable agent).
CHM_FEATURE_AGENT_ACCESS=authenticated

# ── ClickHouse (demo host) ──────────────────────────────────────────────────
# Localhost placeholders — the real demo host topology is injected at deploy from
# CI secrets (CLICKHOUSE_HOST/USER/NAME) so it never lands in the public repo.
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_NAME=localhost
CLICKHOUSE_MAX_EXECUTION_TIME=60

# ── Runtime / platform ──────────────────────────────────────────────────────
# Marks the Cloudflare Worker runtime (set only in the worker, not Docker/Node).
CLOUDFLARE_WORKERS=1
# Default AI model — PUBLIC preset only (keeps the repo generic/OSS). chmonitor's
# own deploy overrides this with its private preset in .env.production.local / CI.
LLM_MODEL=anyrouter:anyrouter/free
# OpenRouter/AnyRouter attribution (non-secret; safe public default).
OPENROUTER_REFERER=https://chmonitor.dev
OPENROUTER_APP_NAME=chmonitor
# AgentState conversation store: the AGENTSTATE_API_KEY secret alone activates
# the backend. All other AgentState knobs (base URL, AI-enrich) use code
# defaults — keep them unset here.

# ── Client-only (build-time inlined; never a worker var) ────────────────────
# Deployment dimension for telemetry.
VITE_DEPLOY_TARGET=cf
