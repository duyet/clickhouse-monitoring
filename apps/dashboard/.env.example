# ============================================================================
# chmonitor dashboard — environment variables (self-hosted / OSS template)
# ============================================================================
# Copy to `.env.local` for local dev, or feed these to Docker / Kubernetes /
# your own Cloudflare Worker. The SAME names work on every target — deploying
# to Docker vs. Wrangler is a config swap, not a re-learn.
#
# ── One canonical name per setting ──────────────────────────────────────────
# Settings the BROWSER needs (auth provider, cloud mode, feature flags) are
# inlined into the client bundle at build time as `VITE_*` (Cloudflare Worker
# runtime vars never reach the browser). You DON'T set those twice: set the
# canonical `CHM_*` value once and `vite.config.ts` derives the matching
# `VITE_*` for the client. e.g. set `CHM_AUTH_PROVIDER` — not also
# `VITE_AUTH_PROVIDER`. (Explicit `VITE_*` / legacy `NEXT_PUBLIC_*` still work
# as overrides for back-compat.)
#
# ── Two kinds of value ──────────────────────────────────────────────────────
#   • non-secret (everything not under "Secrets" below): safe to commit. On
#     Cloudflare these become Worker [vars]; on Docker/K8s they are plain env.
#   • secrets (CLICKHOUSE_PASSWORD, CLERK_SECRET_KEY, *_API_KEY,
#     CHM_CONNECTIONS_ENCRYPTION_KEY, …): NEVER commit. On Cloudflare set via
#     scripts/set-secrets.ts; on K8s via a Secret; locally via .env.local.
#
# The hosted product (dash.chmonitor.dev) keeps its own committed, non-secret
# config in `.env.cloud` (+ `.env.preview`) — that is the single source of truth
# for the Cloud build AND its Worker runtime vars. Self-hosters ignore those and
# use this file.
# ============================================================================

# ── ClickHouse connection (required) ────────────────────────────────────────
# Comma-separated, index-aligned across HOST/USER/NAME/PASSWORD for multi-host.
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_NAME=localhost
CLICKHOUSE_MAX_EXECUTION_TIME=60
# Database holding the monitoring app tables (events etc.). Default 'system'.
# CLICKHOUSE_DATABASE=system
# Fully-qualified monitoring events table. Default `system.monitoring_events`.
# EVENTS_TABLE_NAME=system.monitoring_events

# ── Product mode (canonical CHM_*; drives server + derived client) ──────────
# Cloud (SaaS) mode. Leave UNSET for self-hosted/OSS: your CLICKHOUSE_HOST hosts
# are YOUR real hosts, full access, no demo. 'true' (hosted only) turns env hosts
# into a public read-only demo and gives signed-in users a per-user workspace.
# CHM_CLOUD_MODE=true
# Edition: community (default, OSS) | enterprise (paid).
# CHM_EDITION=community

# ── Auth (canonical CHM_*; drives server + derived client) ──────────────────
# Server-side auth provider: none | clerk | proxy | trusted.
CHM_AUTH_PROVIDER=none
# Clerk PUBLISHABLE key (public, pk_...). Required when CHM_AUTH_PROVIDER=clerk.
# Drives the client VITE_CLERK_PUBLISHABLE_KEY.
# CHM_CLERK_PUBLISHABLE_KEY=
# AI agent access: public | authenticated.
CHM_FEATURE_AGENT_ACCESS=public
# Relax Clerk to public read-only: anonymous GET /api/v1/* allowed; per-route
# feature gates still 401 `authenticated` features. Truthy = 1/true/yes/on.
# CHM_CLERK_PUBLIC_READ=

# ── Feature flags (canonical CHM_*; drives server + derived client) ─────────
# Persist agent conversations in D1/Postgres/AgentState instead of localStorage.
CHM_FEATURE_CONVERSATION_DB=false
# Persist per-user ClickHouse connections (D1/Postgres). Requires Clerk auth +
# CHM_CONNECTIONS_ENCRYPTION_KEY + a database backend (CONVERSATIONS_D1 on
# Cloudflare, or DATABASE_URL/POSTGRES_URL elsewhere). All four must be present
# or the server returns "User connections database storage is not enabled".
CHM_FEATURE_USER_CONNECTIONS_DB=false

# ── AI agent / LLM ──────────────────────────────────────────────────────────
# Default AI model (provider:model or anyrouter:@preset/...).
LLM_MODEL=anyrouter/free
# Extra agent models to expose, comma-separated provider:model ids.
# LLM_EXTRA_MODELS=
# OpenRouter free-tier fallback model (used when the free model is rate-limited).
# OPENROUTER_FREE_FALLBACK_MODEL=
# Override the OpenRouter models catalog endpoint.
# OPENROUTER_MODELS_API=https://openrouter.ai/api/v1/models
# OpenRouter/AnyRouter attribution (non-secret).
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_APP_NAME=chmonitor
# App-attribution metadata sent to LLM providers (all fall back to code defaults).
# APP_REFERER= / APP_NAME= / APP_CATEGORY= / APP_SOURCE= / APP_VERSION=
# Allow the agent's destructive/control tools (KILL QUERY, etc.). Off unless 'true'.
# AGENT_ENABLE_CONTROL_TOOLS=false
# AgentState conversation-store enrichment (auto-titles + follow-ups). Active
# only once the AGENTSTATE_API_KEY secret is set.
# AGENTSTATE_AI_ENRICH=true

# ── Runtime / telemetry ─────────────────────────────────────────────────────
# Set to '1' only inside the Cloudflare Worker runtime (CI/wrangler sets it).
# CLOUDFLARE_WORKERS=1
# Anonymous product telemetry: ON by default — opt out with VITE_TELEMETRY_ENABLED=off
# (or 0/false/no), VITE_DO_NOT_TRACK / DO_NOT_TRACK, or an empty endpoint.
# VITE_TELEMETRY_ENABLED=on
# Deployment target dimension for telemetry: docker | helm | cf | dev | unknown.
# VITE_DEPLOY_TARGET=docker

# ── Proxy / trusted-header auth (CHM_AUTH_PROVIDER=proxy | trusted) ─────────
# Front the app with nginx / k8s ingress / oauth2-proxy / Cloudflare Access.
# Cloudflare Access JWT verification (validates Cf-Access-Jwt-Assertion):
# CHM_CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
# CHM_CF_ACCESS_AUD=
# Trusted-header identity from a reverse proxy, gated by a shared secret:
# CHM_PROXY_AUTH_HEADER=X-Forwarded-User
# CHM_PROXY_SHARED_SECRET_HEADER=X-Chm-Proxy-Secret
# Full trusted-proxy principal (CHM_AUTH_PROVIDER=trusted) — builds name, email,
# avatar, groups, custom claims from forwarded headers. Configure exactly one
# trust gate (fails closed without either):
#   CHM_TRUSTED_AUTH_SECRET    — shared secret the proxy sends per-request (secret).
#   CHM_TRUSTED_ALLOW_INSECURE — skip the secret check; only safe when the service
#                                is reachable ONLY via the proxy (k8s ClusterIP).
# CHM_TRUSTED_ALLOW_INSECURE=false
# CHM_TRUSTED_SHARED_SECRET_HEADER=X-Chm-Proxy-Secret
# Identity header overrides (defaults shown; set X-Auth-Request-* for oauth2-proxy
# with --set-xauthrequest=true):
# CHM_TRUSTED_USER_HEADER=X-Forwarded-User
# CHM_TRUSTED_EMAIL_HEADER=X-Forwarded-Email
# CHM_TRUSTED_NAME_HEADER=X-Forwarded-Preferred-Username
# CHM_TRUSTED_AVATAR_HEADER=X-Forwarded-Avatar
# CHM_TRUSTED_GROUPS_HEADER=X-Forwarded-Groups
# CHM_TRUSTED_ROLE_HEADER=X-Forwarded-Role
# CHM_TRUSTED_CUSTOM_HEADERS=team:X-Forwarded-Team,dept:X-User-Dept
# Deny authenticated users not in the listed groups:
# CHM_TRUSTED_ALLOWED_GROUPS=sre,ops,admin

# ── Secrets — NEVER commit real values ──────────────────────────────────────
# Comma-separated to match the HOST list above.
CLICKHOUSE_PASSWORD=
# Gate /api/v1/* behind chm_ Bearer tokens (HMAC secret for minting/verifying).
CHM_API_KEY_SECRET=
# Clerk server secret (sk_...). Required when CHM_AUTH_PROVIDER=clerk.
CLERK_SECRET_KEY=
# AES-256 key (32-byte base64) encrypting user connection credentials at rest.
# Required when CHM_FEATURE_USER_CONNECTIONS_DB=true or browser session tokens.
CHM_CONNECTIONS_ENCRYPTION_KEY=
# Bearer token guarding the server-to-server agent API (/api/v1/agent).
AGENT_API_TOKEN=
# Shared secrets for proxy / trusted-header auth (see above).
CHM_PROXY_AUTH_SECRET=
CHM_TRUSTED_AUTH_SECRET=
# AI providers (set the one(s) you use).
LLM_API_KEY=
LLM_API_BASE=
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=
ANYROUTER_API_KEY=
ANYROUTER_API_BASE=
NVIDIA_API_KEY=
NVIDIA_API_BASE=
# AgentState project key (as_live_...). Presence activates the AgentState
# conversation-store backend.
AGENTSTATE_API_KEY=

# ── Optional subsystems ─────────────────────────────────────────────────────
# Query timezone / cache.
# CLICKHOUSE_TZ=UTC
# CLICKHOUSE_EXCLUDE_USER_DEFAULT=
# NEXT_QUERY_CACHE_TTL=3600
# Health-sweep cron alerting.
# CRON_SECRET= / HEALTH_ALERT_ENABLED=false / HEALTH_ALERT_MIN_SEVERITY=warning
# HEALTH_ALERT_WEBHOOK_URL=
# PeerDB monitoring.
# PEERDB_API_URL= / PEERDB_PASSWORD=
# User-connections / conversation store backend on non-Cloudflare targets
# (Docker/K8s): Postgres via POSTGRES_URL (or POSTGRES_PRISMA_URL), else DATABASE_URL.
# DATABASE_URL=
# POSTGRES_URL=
# Redis-backed ClickHouse version cache (optional; falls back to in-memory).
# REDIS_URL=
