---
import navData from '../generated/nav.json'
import { resolveSidebarContext, slugToPath, type NavGroup } from '../lib/header-nav'
import { resolveNavIcon } from '../lib/nav-icons'
import NavLinkRow from './NavLinkRow.astro'

interface Props {
  version: string
  currentSlug: string
}
const { version, currentSlug } = Astro.props
const groups = (navData as Record<string, NavGroup[]>)[version] ?? []
const currentPath = slugToPath(currentSlug)
const { category, group, items, showGroupLabel } = resolveSidebarContext(groups, currentPath)
const showSidebar = items.length > 0
---

{
  showSidebar && (
    <nav class="sidebar" aria-label="Documentation navigation">
      {category ? (
        <div class="sidebar__context">
          <span class="sidebar__category">{category.label}</span>
          {showGroupLabel && group ? (
            <span class="sidebar__group">{group.label}</span>
          ) : null}
        </div>
      ) : null}
      <div class="sidebar__items">
        {items.map((item) => (
          <NavLinkRow
            href={item.link}
            label={item.label}
            icon={resolveNavIcon(item.link)}
            current={item.link === currentPath}
            compact
          />
        ))}
      </div>
    </nav>
  )
}