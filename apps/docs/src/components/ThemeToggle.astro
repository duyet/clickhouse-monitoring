---
// Light/dark toggle. The no-FOUC initialization lives in MainLayout's <head>;
// this only handles the click + persistence.
---

<button class="icon-btn" id="theme-toggle" type="button" aria-label="Toggle color theme">
  <svg class="theme-icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  <svg class="theme-icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  :global(:root[data-theme='light']) .theme-icon-dark,
  :global(:root:not([data-theme='dark'])) .theme-icon-dark {
    display: none;
  }
  :global(:root[data-theme='dark']) .theme-icon-light {
    display: none;
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle')
  btn?.addEventListener('click', () => {
    const root = document.documentElement
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
    root.setAttribute('data-theme', next)
    try {
      localStorage.setItem('theme', next)
    } catch {}
  })
</script>
