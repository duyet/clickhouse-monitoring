---
import { SITE } from '../config'
import logo from '../assets/logo.svg'
import versionsData from '../generated/versions.json'
import Search from './Search.astro'
import ThemeToggle from './ThemeToggle.astro'
import VersionSwitcher from './VersionSwitcher.astro'

interface Props {
  version: string
  subpath: string
}
const { version, subpath } = Astro.props
---

<header class="header">
  <a class="header__brand" href={`/${versionsData.latest}`}>
    <img src={logo.src} alt="" width="22" height="22" />
    <span>{SITE.title}</span>
  </a>
  <div class="header__spacer"></div>
  <div class="header__actions">
    <Search />
    <VersionSwitcher version={version} subpath={subpath} />
    <a class="icon-btn" href={SITE.github} target="_blank" rel="noopener" aria-label="GitHub repository">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.22-1.5 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.69 5.41-5.25 5.69.42.36.8 1.08.8 2.18v3.23c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z"></path>
      </svg>
    </a>
    <ThemeToggle />
  </div>
</header>
