---
import { SITE } from '../config'
import HeaderMobileMenu from './HeaderMobileMenu.astro'
import HeaderNav from './HeaderNav.astro'
import Search from './Search.astro'
import ThemeToggle from './ThemeToggle.astro'
import VersionSwitcher from './VersionSwitcher.astro'

interface Props {
  version: string
  subpath: string
  currentSlug: string
}
const { version, subpath, currentSlug } = Astro.props
---

<header class="header">
  <div class="header__top">
    <div class="header__start">
      <a class="header__brand" href="/">
        <img class="header__logo" src="/favicon.svg" width="20" height="20" alt="" aria-hidden="true" />
        <span>{SITE.title}</span>
      </a>
    </div>
    <div class="header__actions">
      <Search />
      <VersionSwitcher version={version} subpath={subpath} />
      <a class="header__cta" href={SITE.dashboard} target="_blank" rel="noopener">
        Dashboard
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
      <a class="icon-btn" href={SITE.github} target="_blank" rel="noopener" aria-label="GitHub repository">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.22-1.5 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.69 5.41-5.25 5.69.42.36.8 1.08.8 2.18v3.23c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z"></path>
        </svg>
      </a>
      <ThemeToggle />
      <button
        class="icon-btn header__menu-toggle"
        id="mobile-nav-toggle"
        type="button"
        aria-label="Open documentation menu"
        aria-expanded="false"
        aria-controls="mobile-nav-modal"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
  <div class="header__sub">
    <HeaderNav version={version} currentSlug={currentSlug} />
  </div>
</header>

<HeaderMobileMenu version={version} currentSlug={currentSlug} />

<script>
  import { initDocsNavShell } from '../scripts/nav-menu'
  initDocsNavShell()
</script>