---
import versionsData from '../generated/versions.json'

interface Props {
  version: string
  subpath: string
}
const { version, subpath } = Astro.props
const { versions, latest } = versionsData
---

{
  versions.length > 1 ? (
    <div class="version-switcher">
      <label class="sr-only" for="version-select">
        Documentation version
      </label>
      <select id="version-select" data-subpath={subpath} data-latest={latest}>
        {versions.map((v) => (
          <option value={v} selected={v === version}>
            {v}
            {v === latest ? ' (latest)' : ''}
          </option>
        ))}
      </select>
    </div>
  ) : (
    <span class="version-switcher" aria-label="Documentation version">
      <select disabled>
        <option>
          {version}
          {version === latest ? ' (latest)' : ''}
        </option>
      </select>
    </span>
  )
}

<script>
  const select = document.getElementById('version-select') as HTMLSelectElement | null
  if (select) {
    select.addEventListener('change', () => {
      const subpath = select.dataset.subpath ?? ''
      const latest = select.dataset.latest ?? ''
      const suffix = subpath ? `/${subpath}` : ''
      // Latest is served at the root (no version prefix); older versions live
      // under /<version>/. Empty suffix on latest means the site root.
      window.location.href =
        select.value === latest ? suffix || '/' : `/${select.value}${suffix}`
    })
  }
</script>
