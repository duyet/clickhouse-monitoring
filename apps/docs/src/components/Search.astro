---
// Pagefind-powered search. The Pagefind UI bundle (/pagefind/pagefind-ui.js)
// is produced by `pagefind --site dist` during build, so search is inert under
// `astro dev` — the button still opens the dialog but reports unavailability.
---

<button class="search-pill" id="search-open" type="button" aria-label="Search docs">
  <svg class="search-pill__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="7"></circle>
    <path d="m21 21-4.3-4.3"></path>
  </svg>
  <span class="search-pill__label">Search</span>
  <span class="search-pill__kbd" aria-hidden="true">⌘K</span>
</button>

<button class="icon-btn search-icon" id="search-open-mobile" type="button" aria-label="Search docs">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="7"></circle>
    <path d="m21 21-4.3-4.3"></path>
  </svg>
</button>

<dialog class="search-modal" id="search-modal">
  <div id="search"></div>
  <p id="search-unavailable" hidden style="color: var(--fg-muted); font-size: 0.85rem; margin: 0.5rem 0 0;">
    Search index is built at deploy time and isn't available in local dev.
  </p>
</dialog>

<style>
  .search-icon {
    display: inline-flex;
  }
  @media (min-width: 1024px) {
    .search-icon {
      display: none;
    }
  }
</style>

<script>
  const openBtns = [
    document.getElementById('search-open'),
    document.getElementById('search-open-mobile'),
  ]
  const modal = document.getElementById('search-modal') as HTMLDialogElement | null
  let initialized = false

  function loadStylesheet(href: string): Promise<void> {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`link[rel="stylesheet"][href="${href}"]`)) {
        resolve()
        return
      }
      const link = document.createElement('link')
      link.rel = 'stylesheet'
      link.href = href
      link.onload = () => resolve()
      link.onerror = () => reject(new Error(`failed to load ${href}`))
      document.head.appendChild(link)
    })
  }

  async function initSearch() {
    if (initialized || !modal) return
    try {
      await loadStylesheet('/pagefind/pagefind-ui.css')
      await new Promise<void>((resolve, reject) => {
        const s = document.createElement('script')
        s.src = '/pagefind/pagefind-ui.js'
        s.onload = () => resolve()
        s.onerror = () => reject(new Error('pagefind unavailable'))
        document.head.appendChild(s)
      })
      // @ts-expect-error — PagefindUI is attached to window by the bundle.
      new window.PagefindUI({ element: '#search', showSubResults: true, showImages: false })
      initialized = true
    } catch {
      const note = document.getElementById('search-unavailable')
      if (note) note.hidden = false
    }
  }

  async function openSearch() {
    await initSearch()
    modal?.showModal()
    setTimeout(() => modal?.querySelector('input')?.focus(), 50)
  }

  for (const btn of openBtns) {
    btn?.addEventListener('click', openSearch)
  }
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.close()
  })
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      openSearch()
    }
  })
</script>