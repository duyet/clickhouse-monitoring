---
import navData from '../generated/nav.json'
import {
  isCategoryActive,
  resolveSidebarContext,
  toHeaderCategories,
  type NavGroup,
} from '../lib/header-nav'
import { resolveNavIcon } from '../lib/nav-icons'
import NavLinkRow from './NavLinkRow.astro'
import NavIcon from './NavIcon.astro'

interface Props {
  version: string
  currentSlug: string
}
const { version, currentSlug } = Astro.props
const groups = (navData as Record<string, NavGroup[]>)[version] ?? []
const currentPath = currentSlug ? `/${currentSlug}` : '/'
const categories = toHeaderCategories(groups)
const { category, group, items, showGroupLabel } = resolveSidebarContext(groups, currentPath)
const sectionTitle = showGroupLabel && group ? group.label : (category?.label ?? 'Docs')
---

<dialog class="mobile-nav-modal" id="mobile-nav-modal" aria-label="Documentation menu">
  <div class="mobile-nav-modal__head">
    <span class="mobile-nav-modal__title">Documentation</span>
    <button class="icon-btn" type="button" data-close-mobile-nav aria-label="Close menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"></path>
      </svg>
    </button>
  </div>
  <div class="mobile-nav-modal__search">
    <svg class="mobile-nav-modal__search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      class="mobile-nav-modal__search-input"
      type="search"
      placeholder="Search docs…"
      autocomplete="off"
      spellcheck="false"
      data-mobile-nav-search
    />
    <kbd class="mobile-nav-modal__search-kbd" aria-hidden="true">Esc</kbd>
  </div>
  <div class="mobile-nav-modal__nav">
    {
      items.length > 0 && (
        <section class="mobile-nav-section mobile-nav-section--current" data-mobile-nav-section>
          <h2 class="mobile-nav-section__title">
            {category ? category.label : sectionTitle}
            {showGroupLabel && group ? (
              <span class="mobile-nav-section__subtitle">{group.label}</span>
            ) : null}
          </h2>
          <div class="mobile-nav-section__links">
            {items.map((item) => (
              <NavLinkRow
                href={item.link}
                label={item.label}
                icon={resolveNavIcon(item.link)}
                current={item.link === currentPath}
                compact
              />
            ))}
          </div>
        </section>
      )
    }

    <section class="mobile-nav-section mobile-nav-section--browse" data-mobile-nav-browse>
      <h2 class="mobile-nav-section__title">Browse</h2>
      <nav aria-label="Documentation categories">
        {
          categories.map((cat) => {
            const active = isCategoryActive(cat, currentPath)
            const hasChildren = cat.items.length > 1

            return hasChildren ? (
              <details
                class="mobile-nav-accordion"
                data-mobile-nav-category
                data-default-open={active ? 'true' : 'false'}
                open={active ? true : undefined}
              >
                <summary class="mobile-nav-accordion__summary">
                  <span class="mobile-nav-accordion__label">{cat.label}</span>
                  <svg class="mobile-nav-accordion__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m6 9 6 6 6-6"></path>
                  </svg>
                </summary>
                <div class="mobile-nav-accordion__panel">
                  <ul class="mobile-nav-accordion__items">
                    {
                      cat.sections.length > 1
                        ? cat.sections.flatMap((section) => [
                            <li class="mobile-nav-accordion__subheading">{section.label}</li>,
                            ...section.items.map((item) => (
                              <li data-mobile-nav-item data-mobile-nav-label={item.label.toLowerCase()}>
                                <a
                                  class="mobile-nav-accordion__link"
                                  href={item.link}
                                  aria-current={item.link === currentPath ? 'page' : undefined}
                                >
                                  <NavIcon name={resolveNavIcon(item.link)} />
                                  <span>{item.label}</span>
                                </a>
                              </li>
                            )),
                          ])
                        : cat.items.map((item) => (
                            <li data-mobile-nav-item data-mobile-nav-label={item.label.toLowerCase()}>
                              <a
                                class="mobile-nav-accordion__link"
                                href={item.link}
                                aria-current={item.link === currentPath ? 'page' : undefined}
                              >
                                <NavIcon name={resolveNavIcon(item.link)} />
                                <span>{item.label}</span>
                              </a>
                            </li>
                          ))
                    }
                  </ul>
                </div>
              </details>
            ) : (
              <a
                class="mobile-nav-accordion__solo"
                href={cat.href}
                aria-current={active ? 'page' : undefined}
              >
                <NavIcon name={resolveNavIcon(cat.href)} />
                <span>{cat.label}</span>
              </a>
            )
          })
        }
      </nav>
    </section>
  </div>
</dialog>

