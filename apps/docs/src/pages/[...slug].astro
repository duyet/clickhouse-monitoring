---
import { getCollection, render } from 'astro:content'
import MainLayout from '../layouts/MainLayout.astro'

export async function getStaticPaths() {
  const entries = await getCollection('docs')
  return entries.map((entry) => ({
    // entry.data.slug is the route: "" -> "/" (latest), else "<path>" (latest)
    // or "<version>/<path>" (older versions). undefined renders the root.
    params: { slug: entry.data.slug || undefined },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)
---

<MainLayout
  title={entry.data.title}
  version={entry.data.version}
  subpath={entry.data.subpath}
  currentSlug={entry.data.slug}
  editUrl={entry.data.editUrl}
  headings={headings}
>
  <Content />
</MainLayout>
