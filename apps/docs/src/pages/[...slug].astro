---
import { getCollection, render } from 'astro:content'
import MainLayout from '../layouts/MainLayout.astro'

export async function getStaticPaths() {
  const entries = await getCollection('docs')
  return entries.map((entry) => ({
    // entry.data.slug is the fully-qualified "<version>/<path>" route.
    params: { slug: entry.data.slug },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)

const version = entry.data.version
// subpath = slug without the leading "<version>/" segment.
const subpath = entry.data.slug.startsWith(`${version}/`)
  ? entry.data.slug.slice(version.length + 1)
  : ''
---

<MainLayout
  title={entry.data.title}
  version={version}
  subpath={subpath}
  currentSlug={entry.data.slug}
  editUrl={entry.data.editUrl}
  headings={headings}
>
  <Content />
</MainLayout>
