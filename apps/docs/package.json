{
  "name": "docs",
  "description": "chmonitor documentation site (docs.chmonitor.dev) — Fumadocs + TanStack Start",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "sync": "node scripts/sync-docs.mjs",
    "dev": "node scripts/sync-docs.mjs && vite dev",
    "build": "node scripts/sync-docs.mjs && node scripts/generate-og.mjs && vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "cf:deploy": "wrangler deploy",
    "types:check": "fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "@takumi-rs/image-response": "^1.8.7",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "fumadocs-core": "^16.10.5",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-twoslash": "^3.0.0",
    "fumadocs-ui": "^16.10.5",
    "lucide-react": "^0.488.0",
    "mermaid": "^11.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.39.2",
    "@cloudflare/workers-types": "^4.20260603.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/mdx": "^2.0.13",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.0",
    "tailwindcss": "^4.1.11",
    "twoslash": "^0.3.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.16",
    "wrangler": "4.65.0"
  }
}
