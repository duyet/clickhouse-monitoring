{
  "name": "docs",
  "description": "chmonitor documentation site (docs.chmonitor.dev)",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-docs.mjs",
    "snapshot": "node scripts/snapshot-version.mjs",
    "dev": "node scripts/sync-docs.mjs && astro dev",
    "build": "node scripts/sync-docs.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "cf:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "astro": "^6.1.10"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "wrangler": "4.65.0"
  }
}
